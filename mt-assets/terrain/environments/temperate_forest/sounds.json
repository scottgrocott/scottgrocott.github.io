{
  "environment": "Temperate Forest",
  "audioConfig": {
    "globalReverb": {
      "decay": 1.5,
      "preDelay": 0.01,
      "wet": 0.2
    },
    "soundscape":[
      {
        "name": "canopy_rustle",
        "description": "Gentle, wide noise sweep imitating leaves.",
        "toneClass": "NoiseSynth",
        "synthConfig": {
          "noise": { "type": "pink" },
          "envelope": { "attack": 1.0, "decay": 1.0, "sustain": 0.8, "release": 2.0 }
